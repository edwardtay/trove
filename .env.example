# 0G Galileo testnet wallet (chainId 16602)
# Get faucet 0G at https://faucet.0g.ai/
# Need testnet 0G for: storage upload txs + iNFT deploy/mint/update txs.
# 0G Compute funding is optional/experimental and not required for the demo.
PRIVATE_KEY=

# 0G testnet endpoints (defaults shown — usually no need to override)
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# 0G Compute provider (experimental upgrade path; not required for demo)
ZG_COMPUTE_PROVIDER=

# Public app URL used in metadata and x402 resource offers
NEXT_PUBLIC_SITE_URL=

# iNFT contract address/token on Galileo
NEXT_PUBLIC_INFT_ADDRESS=
NEXT_PUBLIC_INFT_TOKEN_ID=0

# Optional Base RoyaltyRouter address for paid x402 query revenue
ROYALTY_ROUTER_BASE=

# KeeperHub API key for live workflow status / calls in the UI
# Tx workflow nodes use KeeperHub's organization Turnkey wallet.
# Configure/fund that wallet in KeeperHub UI; it is not an env var here.
KEEPERHUB_API_KEY=

# Privy app ID for live wallet connect (optional; app falls back to demo mode)
NEXT_PUBLIC_PRIVY_APP_ID=
